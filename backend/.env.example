# ── Server ────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000

# ── Database (PostgreSQL) ──────────────────────────────────────
# Option A — single connection string (use this for Supabase, Neon,
# Render, Railway, etc. — copy it straight from your provider).
# For the "roadfund" Supabase project already set up for this app:
# Dashboard > Project Settings > Database > Connection string > Direct connection
DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require

# Option B — discrete vars (used only if DATABASE_URL is unset —
# handy for a plain local Postgres install):
# DB_HOST=localhost
# DB_PORT=5432
# DB_USER=postgres
# DB_PASSWORD=change_me_strong_password
# DB_NAME=roadfund_system

# Set to "disable" only for a local Postgres with no TLS configured.
# Leave unset for Neon/managed providers (they require SSL).
# PGSSL=disable

# ── Auth ──────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=REPLACE_WITH_64_BYTE_RANDOM_HEX
JWT_EXPIRES_IN=7d

# ── Frontend ──────────────────────────────────────────────────
# Comma-separated list of allowed CORS origins
ALLOWED_ORIGINS=http://localhost:5173

# ── File Uploads ──────────────────────────────────────────────
MAX_FILE_SIZE=10485760
