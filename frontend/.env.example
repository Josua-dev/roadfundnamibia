# Only needed for production builds where the frontend and backend are
# deployed as separate services (e.g. Render Static Site + Render Web
# Service). Leave unset for local dev — Vite's proxy in vite.config.ts
# already forwards /api to http://localhost:5000.
#
# Set this in your hosting provider's build-time environment variables,
# pointing at your deployed backend's URL + /api, e.g.:
VITE_API_URL=https://your-backend.onrender.com/api
